# Strapi v5 Environment Variables
# Copy this file to .env and fill in the values

# Server
HOST=0.0.0.0
PORT=1337

# Strapi Secrets (generate with: openssl rand -base64 32)
APP_KEYS=
API_TOKEN_SALT=
ADMIN_JWT_SECRET=
TRANSFER_TOKEN_SALT=
JWT_SECRET=

# Cloudinary Upload Provider
CLOUDINARY_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=

# Database (SQLite by default for development)
DATABASE_FILENAME=.tmp/data.db