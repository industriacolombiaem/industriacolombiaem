# Strapi v5 Environment Variables
# Copy this file to .env and fill in the values

# Server
HOST=0.0.0.0
PORT=1337

# Strapi Secrets (generate with: openssl rand -base64 32)
APP_KEYS=
API_TOKEN_SALT=
ADMIN_JWT_SECRET=
TRANSFER_TOKEN_SALT=
JWT_SECRET=
ENCRYPTION_KEY=

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
# Development: SQLite (default)
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# Production: PostgreSQL (Railway, Neon, Supabese, etc.)
# DATABASE_CLIENT=postgres
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# DATABASE_SSL=true
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=strapi
# DATABASE_USERNAME=strapi
# DATABASE_PASSWORD=strapi
# DATABASE_SCHEMA=public
#
# For client-cert SSL, use DATABASE_SSL=full and provide:
# DATABASE_SSL_KEY=
# DATABASE_SSL_CERT=
# DATABASE_SSL_CA=
# DATABASE_SSL_REJECT_UNAUTHORIZED=true

# ──────────────────────────────────────────────
# Cloudinary Upload Provider
# ──────────────────────────────────────────────
CLOUDINARY_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=