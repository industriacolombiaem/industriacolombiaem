# ──────────────────────────────────────────────────────────
# Strapi v5 — Production Environment (Railway)
# ──────────────────────────────────────────────────────────
# This file documents ALL env vars needed for production.
# Set these in the Railway dashboard (Variables tab) or via
# `railway variables set KEY=VALUE`.
# NEVER commit real production secrets to git.

# Server
HOST=0.0.0.0
PORT=1337

# Strapi Secrets (generate each with: openssl rand -base64 32)
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=
ADMIN_JWT_SECRET=
TRANSFER_TOKEN_SALT=
JWT_SECRET=
ENCRYPTION_KEY=

# ──────────────────────────────────────────────────────────
# Database — PostgreSQL on Railway
# ──────────────────────────────────────────────────────────
# Railway provides DATABASE_URL when you add the PostgreSQL
# plugin. Copy it from the PostgreSQL service variables.
DATABASE_CLIENT=postgres
DATABASE_URL=postgresql://postgres:PASSWORD@HOST.railway.internal:5432/railway

# SSL is required for Railway PostgreSQL
DATABASE_SSL=true

# Connection pool (adjust based on your plan)
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ──────────────────────────────────────────────────────────
# Cloudinary Upload Provider
# ──────────────────────────────────────────────────────────
CLOUDINARY_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=

# ──────────────────────────────────────────────────────────
# Optional: Frontend URL (for CORS and admin redirects)
# ──────────────────────────────────────────────────────────
STRAPI_ADMIN_CLIENT_URL=https://industriacolombiaem.com